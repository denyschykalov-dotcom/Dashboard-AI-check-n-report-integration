# Copy this file to `.env` in the repo root and fill in real values.
# Both the backend (config.py) and the frontend (Vite) read this same file.

# --- Database (required) -----------------------------------------------------
# Postgres/Supabase connection string. For quick local testing without a real
# Postgres instance, a local SQLite file also works:
#   DATABASE_URL=sqlite+pysqlite:///./local_dev.db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional overrides — leave unset to fall back to DATABASE_URL.
# RUNTIME_DATABASE_URL=
# MIGRATION_DATABASE_URL=

# Connection pool tuning (defaults shown; usually fine as-is).
# DB_POOL_MODE=null
# DB_POOL_SIZE=1
# DB_MAX_OVERFLOW=0

# --- Supabase Auth (required to log in) --------------------------------------
# Auth is validated against Supabase's REST API directly — there is no bypass,
# so these must point at a real Supabase project. VITE_-prefixed copies are
# read by the frontend build; the backend accepts either name.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Email granted admin privileges (case-insensitive). Defaults to
# analytics@rankberry.marketing if unset.
# ADMIN_EMAIL=analytics@rankberry.marketing

# --- Report Builder: Google Sheets access (GA4/GSC blocks) -------------------
# Path to a Google service account JSON key (absolute, or relative to the repo
# root) with read access to clients' GA4/GSC data sheets. Without this set,
# GA4/GSC report blocks resolve as "unavailable" rather than erroring.
# GOOGLE_SHEETS_CREDENTIALS_FILE=

# Drive folder ID containing one spreadsheet per client (named after the
# client, e.g. "onebyone.ua"). If a client has no ga4_sheet_id set explicitly,
# the sheet is looked up here by name/domain and the result is cached onto the
# client record. Requires the service account above to also have Drive read
# access to this folder.
# GOOGLE_SHEETS_CLIENT_FOLDER_ID=

# Ahrefs API v3 token (Site Explorer) for the Ahrefs domain-analysis and
# top-movers blocks. Without it, those blocks resolve as "unavailable".
# (ACHREVS_API is accepted too, preserving the existing project spelling.)
# AHREFS_API_TOKEN=

# ClickUp is connected PER USER (each user enters their own personal API token
# in Report Builder settings; it's stored encrypted at rest in the database) —
# there is no shared ClickUp token here.
#
# Fernet key used to encrypt those stored per-user tokens. If unset, a key is
# auto-generated once at backend/data/report_builder_secret.key (gitignored).
# Set this explicitly (same value on every instance) for multi-host prod
# deployments. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REPORT_BUILDER_SECRET_KEY=

# --- LLM providers (only needed for the AI Visibility check feature) ---------
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROK_API_KEY=

# Model overrides (defaults shown).
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_ANALYSIS_MODEL=
# GEMINI_SENTIMENT_MODEL=
# GROK_MODEL=grok-4.3
# GROK_BASE_URL=https://api.x.ai/v1

# --- Runtime tuning (defaults shown; rarely need changing) -------------------
# LOG_LEVEL=INFO
# MAX_LLM_RETRIES=3
# REQUEST_TIMEOUT_SECONDS=60
# RAW_OUTPUT_RETENTION_DAYS=30
# QUEUE_POLL_SECONDS=2
# WORKER_CONCURRENCY=1
# ENFORCE_ONE_ACTIVE_RUN_PER_USER=true
